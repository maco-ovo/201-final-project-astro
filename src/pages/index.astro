---
import Layout from "../layouts/Layout.astro";
import productsData from "../data/products.json";
import { ProductCatalog } from "../logic/ProductCatalog";
import '../styles/global.css'

const catalog = new ProductCatalog(productsData);
const allProducts = catalog.getAllProducts();

const uniqueCategories = [...new Set(allProducts.map(p => p.category))];
---

<Layout title="Jewelry Store">
  <main class="bg-gradient-to-b from-[#BBE2F0] via-white via-20% to-white mx-auto px-16 py-8 min-h-screen">
    <h1 class="font-serif text-gray-800 text-4xl font-bold m-16 text-center">Our Collection</h1>
    
    <!-- 1. The Filter control -->
    <div class="max-w-4xl mx-auto mb-12 flex flex-col sm:flex-row gap-6 justify-center items-center bg-white p-4 rounded-xl shadow-sm border border-gray-100">
      <div class="flex items-center gap-3">
        <label for="category-filter" class="font-semibold text-gray-700">Category:</label>
        <select id="category-filter" class="border border-gray-300 rounded-lg p-2 bg-gray-50 text-gray-800 focus:outline-none focus:border-[#1c97bd] transition-colors">
          <option value="all">All Products</option>
          {uniqueCategories.map(category => (
            <option value={category}>{category.charAt(0).toUpperCase() + category.slice(1)}</option>
          ))}
        </select>
      </div>

      <div class="w-px h-8 bg-gray-200 hidden sm:block"></div>

      <label class="flex items-center gap-3 cursor-pointer group">
        <input type="checkbox" id="stock-filter" class="w-5 h-5 accent-[#1c97bd] cursor-pointer" />
        <span class="text-gray-700 font-semibold group-hover:text-[#1c97bd] transition-colors">In Stock Only</span>
      </label>
    </div>


    <!-- 2. The Product Grid  -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6" id="product-grid">
      {allProducts.map((product) => (
        <div 
          class="product-card bg-gray-50/80 rounded-lg p-5 shadow-md hover:scale-[1.03] hover:shadow-mist-400 duration-300"
          data-category={product.category}
          data-instock={product.inStock.toString()}
        >
          <img src={product.image} alt={product.title} class="w-full h-48 object-cover mb-4 rounded" />
          <h2 class="text-xl font-semibold">{product.title}</h2>
          <p class="text-gray-600 mb-2 capitalize">{product.category}</p>
          <div class="flex justify-between items-center">
            <span class="text-lg font-bold">{product.getFormattedPrice()}</span>
            <span class={`text-sm font-medium ${product.inStock ? 'text-green-600' : 'text-red-500'}`}>
              {product.getAvailabilityMessage()}
            </span>
          </div>
          <a href={`/products/${product.slug}`} class="mt-4 block text-center bg-[#1c97bd] text-white border-white py-2 rounded-full hover:bg-[#1c97bdc4] transition-colors font-medium shadow-sm">
            View Details
          </a>
        </div>
      ))}
    </div>
  </main>


  <script>
    import $ from 'jquery';

    $(document).ready(() => {

      const $categorySelect = $('#category-filter');
      const $stockCheckbox = $('#stock-filter');
      const $allCards = $('.product-card');

      function applyFilters() {
        const selectedCategory = $categorySelect.val();
        const requireInStock = $stockCheckbox.is(':checked');

        // Loop through each card and decide whether to show or hide it
        $allCards.each(function() {
          const $card = $(this);
          
          // Read the data attributes
          const cardCategory = $card.data('category');
          const isCardInStock = $card.data('instock') === true; 

          // Check conditions
          const matchesCategory = (selectedCategory === 'all') || (cardCategory === selectedCategory);
          const matchesStock = !requireInStock || isCardInStock;

          if (matchesCategory && matchesStock) {
            $card.fadeIn(200); 
          } else {
            $card.fadeOut(200);
          }
        });
      }

      // Event listeners
      $categorySelect.on('change', applyFilters);
      $stockCheckbox.on('change', applyFilters);
    });
  </script>
</Layout>